# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n webhook URL (the URL n8n gives you for the webhook trigger node)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Your app URL (used to tell n8n where to POST results back)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Shared secret — add this header in n8n's HTTP Request node when posting results back
# Header name: x-webhook-secret
WEBHOOK_SECRET=generate-a-random-string-here
